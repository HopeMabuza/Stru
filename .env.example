# Gemini (get free key at aistudio.google.com → Get API Key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Demo fallback keeps local development usable if Gemini quota/model access fails.
# Set to false for production so quota errors fail loudly.
AI_DEMO_FALLBACK=true

# Supabase (Settings → API in your Supabase project)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EVIDENCE_BUCKET=evidence

# Solana
ANCHOR_PROVIDER_URL=https://api.devnet.solana.com
ANCHOR_WALLET=./keypairs/oracle.json
PROGRAM_ID=

# Oracle (base58 private key — generated during setup)
ORACLE_WALLET_PRIVATE_KEY=

# Privy (privy.io → App Settings → App ID)
NEXT_PUBLIC_PRIVY_APP_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
VERIFY_PRICE_USDC=0.02
